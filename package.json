{
  "name": "envsafe-crypto",
  "version": "0.0.0",
  "private": true,
  "description": "Open source trust artifacts for envsafe: the crypto core and the CLI.",
  "license": "Apache-2.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "audit": "npm audit --audit-level=high"
  },
  "devDependencies": {
    "@types/node": "24.13.1",
    "typescript": "5.9.3"
  }
}
